# MCP access control
# When set, MCP requests must send: Authorization: Bearer <MCP_BEARER_TOKEN>
MCP_BEARER_TOKEN=

# MCP request governance defaults
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX_REQUESTS=60

# Set to false to suppress MCP audit logs
MCP_AUDIT_LOGGING_ENABLED=true

# MSG91 contact form delivery
# Run `npm run msg91:setup-contact-templates` once to provision or reuse the
# required template identifiers, then set the values below in Vercel.
MSG91_AUTH_KEY=
MSG91_DOMAIN=
MSG91_FROM_EMAIL=
MSG91_FROM_NAME=
MSG91_REPLY_TO_EMAIL=help@vayasyaseva.com
CONTACT_INTERNAL_RECIPIENT_EMAIL=help@vayasyaseva.com
MSG91_INTERNAL_TEMPLATE_ID=
MSG91_AUTOREPLY_TEMPLATE_ID=
